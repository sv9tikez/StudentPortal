<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20261205-010-create-courses" author="Sviatoslav Pinkevych">
        <createTable tableName="courses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="year" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="subject_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="professor_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="courses"
                baseColumnNames="subject_id"
                referencedTableName="subjects"
                referencedColumnNames="id"
                constraintName="fk_courses_subject_id"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="courses"
                baseColumnNames="professor_id"
                referencedTableName="professors"
                referencedColumnNames="user_id"
                constraintName="fk_courses_professor_id"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="courses"
                baseColumnNames="group_id"
                referencedTableName="groups"
                referencedColumnNames="id"
                constraintName="fk_courses_group_id"
                onDelete="RESTRICT"/>
    </changeSet>
</databaseChangeLog>
